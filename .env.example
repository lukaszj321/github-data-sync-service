APP_ENV=local
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://github_data_sync:github_data_sync@db:5432/github_data_sync
GITHUB_TOKEN=
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_API_VERSION=2022-11-28
# GITHUB_USER_AGENT=custom-github-client
GITHUB_CONNECT_TIMEOUT_SECONDS=5
GITHUB_READ_TIMEOUT_SECONDS=15
GITHUB_MAX_ATTEMPTS=3
GITHUB_ISSUES_PER_PAGE=100
GITHUB_MAX_PAGES_PER_SYNC=1000
ISSUES_SYNC_OVERLAP_SECONDS=60
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_RATE_LIMIT_FALLBACK_SECONDS=60
WORKER_STALE_JOB_TIMEOUT_SECONDS=300
WORKER_ID=worker-local
